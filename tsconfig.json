{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],

    /* strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,

    /*  */
    "rootDir": "src",
    "outDir": "dist",

    /* path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@config/*": ["src/config/*"],
      "@modules/*": ["src/modules/*"],
      "@server/*": ["src/server/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
